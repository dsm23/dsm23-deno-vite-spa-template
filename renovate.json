{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:all",
    "helpers:pinGitHubActionDigestsToSemver",
    "schedule:daily",
    "security:openssf-scorecard",
    ":approveMajorUpdates",
    ":enableVulnerabilityAlerts",
    ":pinAllExceptPeerDependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/|\\.)dvmrc$/"],
      "depNameTemplate": "denoland/deno",
      "datasourceTemplate": "github-releases",
      "matchStrings": ["(?<currentValue>\\d+.\\d+.\\d+)\\s"]
    }
  ],
  "packageRules": [
    {
      "description": "Apply minimum release age to all relevant datasources with timestamps",
      "internalChecksFilter": "strict",
      "matchDatasources": [
        "github-releases",
        "github-tags",
        "jsr",
        "node-version",
        "npm"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Apply minimum release age to docker datasource regardless of timestamps",
      "internalChecksFilter": "strict",
      "matchDatasources": ["docker"],
      "minimumReleaseAge": "3 days",
      "minimumReleaseAgeBehaviour": "timestamp-optional"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["denoland/deno"],
      "versioning": "regex:^(?<compatibility>.*)-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ],
  "rebaseWhen": "conflicted",
  "osvVulnerabilityAlerts": true
}
